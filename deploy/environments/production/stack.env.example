COMPOSE_PROJECT_NAME=docly-production
DOCLY_SERVER_NAME=docly.example.com
DOCLY_API_ENV_FILE=/etc/docly/production/api.env
DOCLY_SECRETS_DIR=/etc/docly/production/secrets
DOCLY_TLS_DIR=/etc/docly/production/tls
DOCLY_DB_NAME=docly
DOCLY_DB_USER=postgres
DOCLY_TRUST_PROXY=1
DOCLY_HTTP_PORT=80
DOCLY_HTTPS_PORT=443
DOCLY_HSTS_VALUE=max-age=31536000;includeSubDomains
DOCLY_BACKUP_INTERVAL_SECONDS=86400
DOCLY_BACKUP_RETENTION_DAYS=30
DOCLY_MONITORING_BIND_ADDRESS=127.0.0.1
DOCLY_GRAFANA_PORT=3300
DOCLY_UPTIME_KUMA_PORT=3301
