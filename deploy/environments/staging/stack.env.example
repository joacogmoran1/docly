COMPOSE_PROJECT_NAME=docly-staging
DOCLY_SERVER_NAME=staging.docly.example.com
DOCLY_API_ENV_FILE=/etc/docly/staging/api.env
DOCLY_SECRETS_DIR=/etc/docly/staging/secrets
DOCLY_TLS_DIR=/etc/docly/staging/tls
DOCLY_DB_NAME=docly
DOCLY_DB_USER=postgres
DOCLY_TRUST_PROXY=1
DOCLY_HTTP_PORT=80
DOCLY_HTTPS_PORT=443
DOCLY_HSTS_VALUE=max-age=300
DOCLY_BACKUP_INTERVAL_SECONDS=21600
DOCLY_BACKUP_RETENTION_DAYS=7
DOCLY_MONITORING_BIND_ADDRESS=127.0.0.1
DOCLY_GRAFANA_PORT=3300
DOCLY_UPTIME_KUMA_PORT=3301
