# Server
NODE_ENV=development
PORT=4000
TRUST_PROXY=false
BODY_LIMIT=10mb

# Database
# Render / managed Postgres: podés usar DATABASE_URL en lugar de DB_HOST/DB_NAME/DB_USER/DB_PASSWORD.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=docly
DB_USER=postgres
DB_PASSWORD=change-me
DB_PASSWORD_FILE=
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=20
DB_POOL_MIN=0
DB_POOL_ACQUIRE_MS=30000
DB_POOL_IDLE_MS=10000

# JWT / Cookies
JWT_SECRET=change-me-with-a-long-random-string
JWT_SECRET_FILE=
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false

# CSRF
CSRF_SECRET=change-me-with-another-long-random-string
CSRF_SECRET_FILE=
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=x-csrf-token

# CORS
FRONTEND_URLS=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=10
REGISTER_RATE_LIMIT_WINDOW_MS=3600000
REGISTER_RATE_LIMIT_MAX_REQUESTS=5
REFRESH_RATE_LIMIT_WINDOW_MS=600000
REFRESH_RATE_LIMIT_MAX_REQUESTS=20
PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=3600000
PASSWORD_RESET_RATE_LIMIT_MAX_REQUESTS=5
PASSWORD_RESET_CONFIRM_RATE_LIMIT_WINDOW_MS=1800000
PASSWORD_RESET_CONFIRM_RATE_LIMIT_MAX_REQUESTS=10
SEARCH_RATE_LIMIT_WINDOW_MS=60000
SEARCH_RATE_LIMIT_MAX_REQUESTS=60
AGENDA_RATE_LIMIT_WINDOW_MS=60000
AGENDA_RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_STORE=sequelize
RATE_LIMIT_STALE_ENTRY_MS=3600000
RATE_LIMIT_REDIS_KEY_PREFIX=docly:rate-limit:

# Maintenance
MAINTENANCE_ENABLED=true
MAINTENANCE_RUN_ON_STARTUP=true
MAINTENANCE_CLEANUP_INTERVAL_MS=900000

# Redis (optional)
# Para el arranque barato en Render, dejar RATE_LIMIT_STORE=sequelize y no configurar Redis.
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_PASS_FILE=
EMAIL_FROM="Docly" <no-reply@docly.app>

# Logging
LOG_LEVEL=info
LOG_TO_FILES=true

# Concurrent booking test
BOOKING_TEST_BASE_URL=http://localhost:4000
BOOKING_TEST_PATIENT_EMAIL=
BOOKING_TEST_PATIENT_PASSWORD=
BOOKING_TEST_PATIENTS_JSON=
BOOKING_TEST_PROFESSIONAL_ID=
BOOKING_TEST_OFFICE_ID=
BOOKING_TEST_DATE=
BOOKING_TEST_TIME=
BOOKING_TEST_START_DATE=
BOOKING_TEST_END_DATE=
BOOKING_TEST_CONCURRENCY=5
